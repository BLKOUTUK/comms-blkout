{
  "name": "blkout-remotion-videos",
  "version": "0.1.0",
  "private": true,
  "description": "Weekly IVOR promo videos for events and news digest",
  "scripts": {
    "dev": "remotion studio",
    "render:ivor": "remotion render src/index.ts IVORMessage --output=out/ivor-message.mp4 --concurrency=1 --gl=angle --props=./props/sample-news-digest.json",
    "render:9x16": "remotion render src/index.ts IVORMessage9x16 --output=out/ivor-message-9x16.mp4 --concurrency=1 --gl=angle",
    "render:1x1": "remotion render src/index.ts IVORMessage1x1 --output=out/ivor-message-1x1.mp4 --concurrency=1 --gl=angle",
    "render:16x9": "remotion render src/index.ts IVORMessage16x9 --output=out/ivor-message-16x9.mp4 --concurrency=1 --gl=angle"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.0",
    "@remotion/google-fonts": "4.0.451",
    "@remotion/zod-types": "^4.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "remotion": "^4.0.0",
    "undici": "^7.25.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "typescript": "^5.0.0"
  }
}
